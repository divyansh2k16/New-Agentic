# =====================================================
# FINANCIAL PDF PIPELINE - ENVIRONMENT CONFIGURATION
# =====================================================
# Copy this to .env and fill in your values

# --- LLM API Keys ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here  # Optional fallback

# --- Model Configuration ---
PRIMARY_LLM_MODEL=claude-sonnet-4-6
FAST_LLM_MODEL=claude-haiku-4-5-20251001
EMBEDDING_MODEL=all-MiniLM-L6-v2   # Local sentence-transformers model

# --- LangSmith Monitoring (Free tier available) ---
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=financial-pdf-pipeline

# --- Vector Store ---
CHROMA_PERSIST_DIR=./data/vectorstore
CHROMA_COLLECTION_NAME=financial_documents

# --- API Security ---
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- App Configuration ---
APP_NAME=Financial PDF Pipeline
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# --- File Storage ---
UPLOAD_DIR=./data/pdfs
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# --- AWS (Production Deployment) ---
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=financial-docs-bucket
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0

# --- Redis (Production caching) ---
# REDIS_URL=redis://localhost:6379

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:///./data/app.db
